<div class="potato potato-container">

	<h1 id="potato-title">{{ localize "PotatoOrNot.Selection"}}</h1>

	<div class='potato-master-container'>
		<div class="potato-level-container" data-level="0" role="radio" tabindex="0" aria-checked="{{#if (eq potatoQuality 0)}}true{{else}}false{{/if}}">
			<div class="potato-level-row">
				<img src="modules/potato-or-not/styles/img/bad_potato.jpg" alt="">
			</div>
			<div class="potato-level-row-text">
				<h2>{{ localize "PotatoOrNot.BadTitle" }}</h2>
				<p>{{ localize "PotatoOrNot.BadDescription" }}</p>
			</div>
		</div>
		<div class="potato-level-container" data-level="1" role="radio" tabindex="0" aria-checked="{{#if (eq potatoQuality 1)}}true{{else}}false{{/if}}">
			<div class="potato-level-row">
				<img src="modules/potato-or-not/styles/img/potato.png" alt="">
			</div>
			<div class="potato-level-row-text">
				<h2>{{ localize "PotatoOrNot.MediumTitle" }}</h2>
				<p>{{ localize "PotatoOrNot.MediumDescription" }}</p>
			</div>
		</div>
		<div class="potato-level-container" data-level="2" role="radio" tabindex="0" aria-checked="{{#if (eq potatoQuality 2)}}true{{else}}false{{/if}}">
			<div class="potato-level-row">
				<img src="modules/potato-or-not/styles/img/good_potato.jpg" alt="">
			</div>
			<div class="potato-level-row-text">
				<h2>{{ localize "PotatoOrNot.GoodTitle" }}</h2>
				<p>{{ localize "PotatoOrNot.GoodDescription" }}</p>
			</div>
		</div>
	</div>

	<hr>

	<button type="submit" class="dialog-button" data-action="confirm">
		<i class="fa-solid fa-potato"></i>
		{{ localize "PotatoOrNot.Accept" }}
	</button>

</div>
